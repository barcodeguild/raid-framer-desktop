    <!-- Companion Addon Settings Strings -->
    <string name="companion_description">The Lua Addon sources combat data from the game. It's what allows for native-only functionality like target-based debuff tracking, raid management, and in-game visual/audible effects. If you remove the lua addon from the game features won't work as intended.</string>
    <string name="companion_toggle_raid_status">Display the main / co-raid member count when players join or leave the raid.</string>
    <string name="companion_toggle_display_charmed">Display 'Charmed' targets in game chat window.</string>
    <string name="companion_toggle_display_silenced">Display 'Silenced' targets in game chat window.</string>
    <string name="companion_toggle_display_distressed">Display 'Distressed' targets in game chat window.</string>
    <string name="companion_toggl_display_mark_hvt_healers">Show a [Heart Mark] over highest-value enemy healers. (Top 3 enemy healers based on cumulative PvP healing.)</string>
    <string name="companion_toggle_display_mark_hvt_dps">Show a [Crossed-Swords Mark] over highest-value enemy DPS. (Top 3 enemy DPS based on cumulative PvP damage.)</string>
    <string name="companion_toggle_display_mark_hvt_cc">Show a [Shield Mark] over high-value enemy CC mages to stay away from. (Top 3 enemy CC based on cumulative PvP crowd control time.)</string>
    <string name="companion_toggle_display_mark_sac_dancers">Sheen a God ray over sacrifice dancers while they are channeling. (Easier to spot than default game effect.)</string>
    <string name="companion_toggle_display_mark_charmed_targets">Show a [Purple Dot] over player's heads to indicate that they are Charmed.</string>
    <string name="companion_toggle_display_mark_silenced_targets">Show a [Black Dot] over player's heads to indicate that they are Silenced.</string>
    <string name="companion_toggle_display_mark_distressed_targets">Show a [Blue Dot] over player's heads to indicate that they are Distressed.</string>

    <!-- Settings Overlay -->
    <string name="settings_title">Raid Framer Desktop Settings</string>
    <string name="settings_data_sourcing_title">Data Sourcing</string>
    <string name="settings_data_sourcing_description">Please be careful to enter the correct ArcheRage directory below. This field was likely populated automatically: </string>
    <string name="settings_data_sourcing_sidenote">Technically, you do not need ArcheRage installed if you only want to view historical combat.log files. Just right-click on the .log or .rf (battle slice export file) and choose 'Open-With → Raid Framer' in the Windows Explorer context menu to view a replay.</string>
    <string name="settings_toggle_pvp_damage">Show only PvP damage</string>
    <string name="settings_toggle_show_mini_graph">Enable mini DPS/HEALS/CC graph overlay</string>
    <string name="settings_lua_options_title">Lua Options</string>
    <string name="settings_uninstall_title">Uninstall Raid Framer</string>
    <string name="settings_name_placeholder">Game Character Select</string>
    <string name="settings_uninstall_description">Uninstalling via this menu cleanly removes the Lua addon from the game folder, it also closes the app, and triggers the regular un-installation process. If you decide to cancel the installer, opening raid framer again will allow you to re-install the Lua component automatically.</string>
    <string name="settings_arche_rage_directory_label">ArcheRage Documents Directory:</string>
    <string name="settings_specify_directory_hint">Please Specify Directory (It's the folder that has a system.cfg file inside it!)</string>
    <string name="settings_lua_companion_options">Lua Companion Options</string>
    <string name="settings_your_current_character">Your Current Character</string>
    <string name="settings_character_note">Switch characters in-game to update this value automatically.</string>
    <string name="settings_enter_name_placeholder">Enter Character Name</string>
    <string name="settings_uninstall_done_text">The Lua Addon has been safely removed from your game folder.\n\n**HOWEVER**\n\nYou should still complete the uninstallation of the main application by uninstalling "Raid Framer" via the Windows Control Panel. (that's this app) If you don't uninstall, and decide to open the app again, the Lua addon will be copied back to your game folder in the interest of the addon still functioning. (at your desire) Thanks! Exiting now!</string>
    <string name="settings_mini_graph_description">Enable DPS/HEALS/CC Mini-Graph. Shows performance over time.</string>
    <string name="settings_show_heals_column">Show Heals Column</string>
    <string name="settings_show_cc_column">Show CC Column</string>
    <string name="settings_show_damage_column">Show Damage Column</string>
    <string name="settings_combat_overlay_title">Combat Overlay</string>
    <string name="settings_combat_fade_controls">Auto-fade icon controls when the cursor leaves the overlay.</string>
    <string name="settings_split_chat">Enable OSRS-style split-chat window overlay. (Coming Soon)</string>
    <string name="settings_tabbed_detection">Automatically hide game overlay's while tabbed-out of the game. Doesn't apply to tool-tips (those with a title-bar).</string>
    <string name="settings_allow_pve_damage">Allow PvE Damage to be counted towards DPS/Kill Counters. (Useful for solo players who want to see their damage output against PvE targets)</string>
    <string name="settings_game_schedule_hotkey">Enable [HOLD TAB] to bring-up the official in-game event schedule website as an overlay. (Coming Soon)</string>
    <string name="settings_use_sadly">I'd prefer to use Sadly.io for in-game schedule data. (Coming Soon)</string>
    <string name="settings_dragon_breath_overlay">Enable dragon breath detector and counter overlay. (Note: You still have be in 100 meter range of the dragon rider to witness the breaths, this isn't magic friends!) (Coming Soon)</string>
    <string name="settings_uninstall_confirm_title">Confirm Uninstall</string>
    <string name="settings_uninstall_confirm_text">Are you sure you want to uninstall the Lua Addon? This will remove the game integration.\n\nPlease close the game before continuing, otherwise files will be left over.</string>
    <string name="settings_uninstall_confirm_button">Uninstall</string>
    <string name="settings_uninstall_done_title">Uninstall Complete</string>
    <string name="settings_character_description">Your character and faction are determined automatically when you switch characters. Raid Framer uses this information to deduce friendly and hostile characters over time.</string>
